<?xml version='1.0' encoding='UTF-8'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="quadrotor">

    <xacro:include filename="gazebo_full.xacro" />
    
    <!-- Base Link -->
    <link name="base_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${mass}"/>
            <inertia ixx="0.0347563" ixy="0" ixz="0" iyy="0.07" iyz="0" izz="0.0977"/>
        </inertial>
        <collision name="base_link_collision">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.47 0.47 0.11"/>
            </geometry>
        </collision>
        <visual name="base_link_visual">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find quad_description)/meshes/x3.dae" scale="1 1 1"/>
            </geometry>
        </visual>
    </link>

    <!-- IMU Link -->
    <link name="imu_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.005"/>
            <inertia ixx="8.33e-06" ixy="0" ixz="0" iyy="8.33e-06" iyz="0" izz="8.33e-06"/>
        </inertial>
    </link>

    <!-- IMU Joint -->
    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Rotor 0 -->
    <link name="rotor_0">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.005"/>
            <inertia ixx="9.75e-07" ixy="0" ixz="0" iyy="4.17041e-05" iyz="0" izz="4.26041e-05"/>
        </inertial>
        <collision name="rotor_0_collision">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.005" radius="0.1"/>
            </geometry>
        </collision>
        <visual name="rotor_0_visual">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find quad_description)/meshes/ccw.stl" scale="1 1 1"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>

    <!-- Rotor 0 joint (front-right) -->
    <joint name="rotor_0_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rotor_0"/>
        <origin xyz="0.13 -0.22 0.023" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- Rotor 1 -->
    <link name="rotor_1">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.005"/>
            <inertia ixx="9.75e-07" ixy="0" ixz="0" iyy="4.17041e-05" iyz="0" izz="4.26041e-05"/>
        </inertial>
        <collision name="rotor_1_collision">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.005" radius="0.1"/>
            </geometry>
        </collision>
        <visual name="rotor_1_visual">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find quad_description)/meshes/ccw.stl" scale="1 1 1"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
    </link>

    <!-- Rotor 1 joint (rear-left) -->
    <joint name="rotor_1_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rotor_1"/>
        <origin xyz="-0.13 0.2 0.023" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>


    <!-- Rotor 2 -->
    <link name="rotor_2">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.005"/>
            <inertia ixx="9.75e-07" ixy="0" ixz="0" iyy="4.17041e-05" iyz="0" izz="4.26041e-05"/>
        </inertial>
        <collision name="rotor_2_collision">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.005" radius="0.1"/>
            </geometry>
        </collision>
        <visual name="rotor_2_visual">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find quad_description)/meshes/cw.stl" scale="1 1 1"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>

    <!-- Rotor 2 joint (front-left) -->
    <joint name="rotor_2_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rotor_2"/>
        <origin xyz="0.13 0.22 0.023" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- Rotor 3 -->
    <link name="rotor_3">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.005"/>
            <inertia ixx="9.75e-07" ixy="0" ixz="0" iyy="4.17041e-05" iyz="0" izz="4.26041e-05"/>
        </inertial>
        <collision name="rotor_3_collision">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.005" radius="0.1"/>
            </geometry>
        </collision>
        <visual name="rotor_3_visual">
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find quad_description)/meshes/cw.stl" scale="1 1 1"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
    </link>

    <!-- Rotor 3 joint (rear-right) -->
    <joint name="rotor_3_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rotor_3"/>
        <origin xyz="-0.13 -0.2 0.023" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>


</robot>
